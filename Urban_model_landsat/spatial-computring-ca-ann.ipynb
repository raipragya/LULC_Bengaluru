    "# %% Cell 15: Save predicted maps as individual PNG files\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.colors as mcolors\n",
    "\n",
    "# Define the exact same colors used in the grid\n",
    "cmap = mcolors.ListedColormap(['black', '#e41a1c', '#4daf4a', '#377eb8', '#984ea3'])\n",
    "bounds = [0, 1, 2, 3, 4, 5]\n",
    "norm = mcolors.BoundaryNorm(bounds, cmap.N)\n",
    "\n",
    "def save_clean_png(data, filename):\n",
    "    \"\"\"Saves a 2D array as a clean PNG with no borders or axes.\"\"\"\n",
    "    # Set figsize relative to your array dimensions to avoid stretching\n",
    "    fig, ax = plt.subplots(figsize=(10, 10))\n",
    "    ax.imshow(data, cmap=cmap, norm=norm, interpolation='nearest')\n",
    "    ax.axis('off')\n",
    "    \n",
    "    # bbox_inches='tight' and pad_inches=0 removes all whitespace around the map\n",
    "    plt.savefig(filename, dpi=300, bbox_inches='tight', pad_inches=0, transparent=True)\n",
    "    plt.close(fig)\n",
    "    print(f\"Saved: {filename}\")\n",
    "\n",
    "# Save the two predictions\n",
    "# Save the historical LULC maps as well\n",
    "save_clean_png(lulc_2005, 'classified_2005.png')\n",
    "save_clean_png(lulc_2015, 'classified_2015.png')\n",
    "save_clean_png(lulc_2025, 'classified_2025.png')\n",
    "save_clean_png(pred_2035, 'classified_2035.png')\n",
    "save_clean_png(pred_2045, 'classified_2045.png')\n"
   ]
  }
