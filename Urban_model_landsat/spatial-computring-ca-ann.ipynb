    "def load_raster(path):\n",
    "    \"\"\"Load a single-band raster and return data, transform, meta.\"\"\"\n",
    "    with rasterio.open(path) as src:\n",
    "        return src.read(1).astype(np.float32), src.transform, src.meta\n",
    "\n",
    "def get_fast_neighborhood(lulc_map, window_size=3, n_classes=4):\n",
    "    \"\"\"Extract neighborhood class proportions + center pixel one-hot.\"\"\"\n",
    "    padding = window_size // 2\n",
    "    padded = np.pad(lulc_map, padding, mode='edge')\n",
    "    windows = sliding_window_view(padded, (window_size, window_size))\n",
    "    flat_windows = windows.reshape(-1, window_size * window_size)\n",
    "    \n",
    "    n_pixels = flat_windows.shape[0]\n",
    "    n_cells = window_size * window_size\n",
    "    \n",
    "    # Neighborhood proportions (all cells including center)\n",
    "    proportions = np.zeros((n_pixels, n_classes), dtype=np.float32)\n",
    "    for c in range(1, n_classes + 1):\n",
    "        proportions[:, c - 1] = np.sum(flat_windows == c, axis=1) / n_cells\n",
    "    \n",
    "    # Center pixel one-hot encoding\n",
    "    center = flat_windows[:, n_cells // 2].astype(int)\n",
    "    center_onehot = np.zeros((n_pixels, n_classes), dtype=np.float32)\n",
    "    for c in range(1, n_classes + 1):\n",
    "        center_onehot[:, c - 1] = (center == c).astype(np.float32)\n",
    "    \n",
    "    return np.hstack([proportions, center_onehot])\n"
   ]
